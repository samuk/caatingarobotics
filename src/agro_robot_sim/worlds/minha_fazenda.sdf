    <!-- ── GUI camera hint ───────────────────────────────────────────────── -->
    <gui fullscreen='false'>
      <camera name='user_camera'>
        <pose>9.620 22.205 9.735 0 0.608 -0.939</pose>
      </camera>
    </gui>

  </world>
</sdf>
