    <model name='row3_post_0'><static>true</static><pose>2.089 6.051 1.095 0 0 -0.0025</pose>
      <link name='link'><collision name='c'><geometry><box><size>0.119 0.117 2.189</size></box></geometry></collision>
      <visual name='v'><geometry><box><size>0.119 0.117 2.189</size></box></geometry><material><ambient>0.4 0.6 0.2 1</ambient></material></visual></link></model>

